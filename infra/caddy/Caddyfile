# Единый веб-контейнер: TLS (авто-HTTPS) + раздача SPA + проксирование /api на backend.
# Заменяет связку «nginx фронта + отдельный Caddy» (минус один контейнер).
#
# SITE_ADDRESS задаётся в .env:
#   - доменное имя (school2090.example.org) → Caddy сам выпустит и продлит TLS-сертификат;
#   - ":80" → только HTTP (локальный демо-режим или работа за внешним прокси школы).

{$SITE_ADDRESS} {
	encode gzip

	# Базовые security-заголовки для статики SPA (для API их добавляет backend).
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		-Server
	}

	# API → backend (тот же origin, без CORS).
	# WebSocket (/api/v1/ws): Caddy проксирует Upgrade-запросы прозрачно, отдельный
	# matcher не нужен. Для долгоживущих WS-соединений снимаем таймауты потоковой
	# передачи у этого reverse_proxy (по умолчанию они уже отключены, но фиксируем
	# явно, чтобы апгрейд чата/уведомлений не рвался прокси).
	handle /api/* {
		reverse_proxy backend:8000 {
			transport http {
				# 0 = без принудительного закрытия простаивающего соединения,
				# что важно для idle WS между сообщениями чата.
				read_timeout 0
				write_timeout 0
			}
		}
	}

	# SPA: статика + fallback на index.html для клиентского роутинга
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
