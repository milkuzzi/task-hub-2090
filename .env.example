# ===== Шаблон конфигурации (скопируйте в .env и заполните) =====
# cp .env.example .env  → отредактируйте секреты → docker compose up -d
# Реальный .env в репозиторий НЕ коммитится (см. .gitignore).

# --- Окружение ---
APP_ENV=prod                 # dev | prod
LOG_LEVEL=INFO

# --- База данных ---
POSTGRES_USER=taskhub
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=taskhub
DATABASE_URL=postgresql+asyncpg://taskhub:change-me-strong-password@db:5432/taskhub

# --- JWT / секреты (ОБЯЗАТЕЛЬНО смените в проде; с дефолтным значением backend в проде не стартует) ---
# Сгенерировать: python3 -c 'import secrets; print(secrets.token_urlsafe(48))'
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL_MIN=15
REFRESH_TTL_DAYS=14
PASSWORD_RESET_TTL_MIN=60

# --- SMTP (обязательный канал уведомлений) ---
SMTP_HOST=smtp.example.org
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=noreply@school2090.example.org

# --- MAX (best-effort, опционально) ---
MAX_ENABLED=false
MAX_API_BASE=
MAX_BOT_TOKEN=
MAX_BLOCKED_EXT=.html,.htm,.svg
MAX_FILE_SIZE_MB=20

# --- Хранилище вложений ---
STORAGE_BACKEND=file
ATTACHMENTS_DIR=/data/attachments

# --- Лимиты загрузки ---
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_TASK=20
MAX_FILES_PER_REPORT=10
MAX_TASK_TOTAL_MB=200
MAX_OBSERVERS=5
# Предел объёма вложений, инлайнящихся в письмо (на файл и суммарно). Файлы крупнее
# не вкладываются в письмо, а заменяются ссылкой в теле — защита воркера от OOM.
MAX_EMAIL_ATTACHMENT_MB=10

# --- Таймзона и расписание ---
TZ=Europe/Moscow
NOTIFY_TIME=09:00            # время суточной рассылки уведомлений
OVERDUE_SWEEP_MINUTES=10     # интервал прохода флага «Просрочена»
# Планировщик внутри backend-процесса (3 контейнера вместо 4). По умолчанию false —
# отдельный контейнер worker (изоляция отказов). Если true — запускайте без worker:
#   docker compose up -d db backend web
SCHEDULER_IN_PROCESS=false

# --- Rate limit на auth-эндпоинты (вход/регистрация/сброс пароля; защита от перебора) ---
AUTH_RATE_LIMIT_ENABLED=true

# --- Доверенные прокси (X-Forwarded-* / реальный IP клиента) ---
# uvicorn доверяет заголовкам X-Forwarded-* только от перечисленных адресов/подсетей.
# Если оставить '*', любой клиент сможет подделать X-Forwarded-For и обойти
# rate limiter аутентификации. По умолчанию доверяем только внутренней сети Docker,
# где работает обратный прокси Caddy. Поддерживается список через запятую и CIDR.
# Если backend стоит за внешним прокси школы — укажите его адрес/подсеть.
FORWARDED_ALLOW_IPS=172.16.0.0/12

# --- Адрес / доступ ---
BASE_URL=https://school2090.example.org
CORS_ORIGINS=https://school2090.example.org,http://localhost:5173
SITE_ADDRESS=:80            # домен для Caddy (авто-HTTPS), например school2090.example.org;
                            # ":80" — HTTP-демо без домена / работа за внешним прокси школы

# --- Первичный администратор (создаётся сид-скриптом) ---
ADMIN_EMAIL=director@school2090.example.org
ADMIN_PASSWORD=change-me-admin-password
RUN_SEED=true
# SEED_REGISTRY_FILE=/app/seed/registry.txt   # опц.: начальный реестр сотрудников
